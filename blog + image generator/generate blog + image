def validate_svg(svg_content: str) -> bool:
    """Basic SVG sanity checks before saving."""
    checks = [
        svg_content.strip().startswith('<svg'),
        svg_content.strip().endswith('</svg>'),
        'href=' not in svg_content or 'data:' in svg_content,  # no external refs
        '@import' not in svg_content,  # no external fonts
    ]
    return all(checks)
```